          "$ref": "#/$defs/CategoryStrict"
        },
        {
          "type": "string"
        }
      ],
      "title": "Category"
    },
    "files": {
      "additionalProperties": {
        "discriminator": {
          "mapping": {
            "folder": "#/$defs/FolderFile",
            "multi_files": "#/$defs/MultiFilesField",
            "single_file": "#/$defs/SingleFileField",
            "zip": "#/$defs/ZipFile"
          },
          "propertyName": "type"
        },
        "oneOf": [
          {
            "$ref": "#/$defs/SingleFileField"
          },
          {
            "$ref": "#/$defs/MultiFilesField"
          },
          {
            "$ref": "#/$defs/FolderFile"
          },
          {
            "$ref": "#/$defs/ZipFile"
          }
        ]
      },
      "title": "Files",
      "type": "object"
    },
    "icon": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Icon"
    },
    "id": {
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "title": "Id",
      "type": "string"
    },
    "inputs": {
      "additionalProperties": {
        "discriminator": {
          "mapping": {
            "checkbox": "#/$defs/CheckboxField",
            "date": "#/$defs/DateField",
            "number": "#/$defs/NumberField",
            "radio": "#/$defs/RadioField",
            "select": "#/$defs/SelectField",
            "text": "#/$defs/TextField",
            "textarea": "#/$defs/TextareaField"
          },
          "propertyName": "type"
        },
        "oneOf": [
          {
            "$ref": "#/$defs/TextField"
          },
          {
            "$ref": "#/$defs/TextareaField"
          },
          {
            "$ref": "#/$defs/NumberField"
          },
          {
            "$ref": "#/$defs/CheckboxField"
          },
          {
