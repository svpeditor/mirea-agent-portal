          },
          {
            "$ref": "#/$defs/DateField"
          }
        ]
      },
      "title": "Inputs",
      "type": "object"
    },
    "name": {
      "minLength": 1,
      "title": "Name",
      "type": "string"
    },
    "outputs": {
      "items": {
        "$ref": "#/$defs/OutputField"
      },
      "minItems": 1,
      "title": "Outputs",
      "type": "array"
    },
    "runtime": {
