# Скопируй в .env, заполни секретами:
#   cp .env.example .env

# === Обязательное ===

# Секрет для JWT — минимум 32 символа.
# Генерация: openssl rand -hex 32
JWT_SECRET=сгенерить-командой-openssl-rand-hex-32

# Первый админ — создаётся при первом старте api.
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=ChangeMeOnFirstLogin

# Среда — dev | prod.
ENVIRONMENT=dev

# Только в dev: hot-reload uvicorn.
RELOAD=1

# === LLM-прокси (опционально) ===

# Без OPENROUTER_API_KEY агенты с runtime.llm запустятся, но прокси-запросы
# к OpenRouter будут отбиваться 401.
OPENROUTER_API_KEY=sk-or-v1-...

# Whitelist моделей (CSV без пробелов). Агент может запросить любую отсюда,
# и manifest.runtime.llm.models должен быть подмножеством.
LLM_ALLOWED_MODELS=openai/gpt-4o-mini,anthropic/claude-3.5-haiku,openai/gpt-4o,deepseek/deepseek-r1

# === Sentry (опционально, только prod) ===
# Без SENTRY_DSN init no-op.
# SENTRY_DSN=https://<key>@sentry.example.com/<project>
# SENTRY_RELEASE=portal-0.1.0
# SENTRY_TRACES_SAMPLE_RATE=0.1

# === Prod-only ===
# PUBLIC_DOMAIN=portal.mirea.ru
