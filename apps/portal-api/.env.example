DATABASE_URL=postgresql+asyncpg://portal:portal@postgres:5432/portal
JWT_SECRET=сгенерить-командой-openssl-rand-base64-64
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=ChangeMeOnFirstLogin
ALLOWED_ORIGINS=["http://localhost:3000"]
COOKIE_SECURE=false
ENVIRONMENT=dev
REDIS_URL=redis://redis:6379/0

# Лимиты и хранилище для jobs (1.2.3)
MAX_JOB_INPUT_BYTES=104857600
MAX_JOB_OUTPUT_BYTES=1073741824
JOB_TIMEOUT_SECONDS=1800
FILE_STORE_BACKEND=local
FILE_STORE_LOCAL_ROOT=/var/portal-files

# LLM proxy (1.2.4)
OPENROUTER_API_KEY=sk-or-v1-CHANGE-ME
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_ALLOWED_MODELS=deepseek/deepseek-chat,anthropic/claude-haiku-4-5,openai/gpt-5-mini
LLM_DEFAULT_USER_QUOTA_USD=5.0
LLM_DEFAULT_PER_JOB_CAP_USD=0.5
LLM_PRICING_REFRESH_INTERVAL_SECONDS=21600
LLM_REQUEST_TIMEOUT_SECONDS=30
LLM_PROXY_BASE_URL=http://portal-api:8000/llm/v1
