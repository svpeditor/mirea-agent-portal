# API backend (server-side fetch — internal Docker DNS)
API_BASE_URL=http://api:8000

# WebSocket URL для browser (external)
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# App branding
NEXT_PUBLIC_APP_NAME=Портал НУГ

# Disable Next.js telemetry
NEXT_TELEMETRY_DISABLED=1

# E2E (Playwright) — требует docker compose up для backend и seed-данных
E2E_API_BASE=http://localhost:8000
E2E_BASE_URL=http://localhost:3000
E2E_ADMIN_EMAIL=admin@test.local
E2E_ADMIN_PASSWORD=admin-test-password-12345
E2E_USER_EMAIL=user@test.local
E2E_USER_PASSWORD=user-test-password-12345
E2E_ECHO_AGENT_SLUG=echo
E2E_LLM_AGENT_SLUG=echo-llm
